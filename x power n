class Solution {
    public double mypow(double x,int n){
        if(n==0) return 1;
        double half=mypow(x,n/2);
        if(n%2==0){
            return half*half;
        }
        return half*half*x;
    }
    public double myPow(double x, int n) {
        if(n==0) return 1;
        long N=n;
        while(N<0){
            x=1/x;
            N=-N;
        }
        return mypow(x,n);
    }
}
time-o(logn)
space-o(logn)
