class Solution{
  public static void helper(int index,int n ,String result){ 
    if(index==n){
       System.out.println(result);
       return;
    }
   helper(index+1,n,result+'0');
   if(result.length()==0 || result.charAt(result.length()-1)!='1'){
       helper(index+1,n,result+'1');
    }
  }

  public static void generatestring(int n){
    helper(0,n,"");
  }
}
time-o(2n)
space-o(n)
