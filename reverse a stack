import java.util.*;

class Solution {

    static void insertAtBottom(Stack<Integer> st, int x) {
        if (st.isEmpty()) {
            st.push(x);
            return;
        }

        int temp = st.pop();
        insertAtBottom(st, x);
        st.push(temp);
    }

    static void reverse(Stack<Integer> st) {
        if (!st.isEmpty()) {
            int x = st.pop();
            reverse(st);
            insertAtBottom(st, x);
        }
    }
}
time-o(n2)
space-o(n)
